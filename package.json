{
  "name": "unboxers-assignment-mock-exam",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n \"server,web\" -c \"blue,green\" \"pnpm --filter server dev\" \"pnpm --filter web dev\"",
    "db:generate": "pnpm --filter server db:generate",
    "db:push": "pnpm --filter server db:push",
    "db:seed": "pnpm --filter server db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}